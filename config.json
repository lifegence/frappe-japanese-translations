{
  "version": "2.0.0",
  "language": "ja",
  "apps": {
    "frappe": {
      "type": "core",
      "format": "po",
      "crowdin": true,
      "repo": "https://github.com/frappe/frappe",
      "pot_path": "frappe/locale/main.pot"
    },
    "erpnext": {
      "type": "core",
      "format": "po",
      "crowdin": true,
      "repo": "https://github.com/frappe/erpnext",
      "pot_path": "erpnext/locale/main.pot"
    },
    "hrms": {
      "type": "core",
      "format": "po",
      "crowdin": true,
      "repo": "https://github.com/frappe/hrms",
      "pot_path": "hrms/locale/main.pot"
    },
    "healthcare": {
      "type": "community",
      "format": "po",
      "crowdin": true,
      "repo": "https://github.com/frappe/health",
      "pot_path": "healthcare/locale/main.pot"
    },
    "lending": {
      "type": "community",
      "format": "po",
      "crowdin": true,
      "repo": "https://github.com/frappe/lending",
      "pot_path": "lending/locale/main.pot"
    },
    "posawesome": {
      "type": "community",
      "format": "csv",
      "crowdin": false,
      "repo": "https://github.com/yrestom/POS-Awesome",
      "notes": "Legacy CSV format; no upstream PO / Crowdin path. Local bench deploy only."
    }
  },
  "defaults": {
    "bench_path": "~/work/frappe-bench",
    "site": "dev.localhost",
    "docker_bench": "bench-01",
    "docker_container_bench_path": "/home/frappe/frappe-bench",
    "pot_root": "~/work/frappe-i18n-upstream"
  },
  "glossary_path": "glossary/glossary.csv"
}
